# === REQUIRED ===
AIRTABLE_API_KEY=           # Airtable Personal Access Token (https://airtable.com/create/tokens)
APIFY_TOKEN=                # Apify API token (https://console.apify.com/account/integrations)

# === REQUIRED FOR AD MANAGEMENT ===
META_ACCESS_TOKEN=          # Meta system user token — never expires (Business Settings > System Users)
META_AD_ACCOUNT_ID=         # Format: act_XXXXXXXXX

# === REQUIRED FOR ANALYSIS ===
# Pick ONE transcription method:
# Option A: Local whisper.cpp (free — install separately: https://github.com/ggerganov/whisper.cpp)
# Option B: OpenAI Whisper API
OPENAI_API_KEY=             # For Whisper API transcription (https://platform.openai.com/api-keys)

# For visual analysis (optional but recommended):
GEMINI_API_KEY=             # Google Gemini API key (https://aistudio.google.com/apikey)

# === FOR IMAGE GENERATION (pick one, all optional) ===
# Gemini CLI: install separately (https://github.com/google-gemini/gemini-cli)
# DALL-E: uses OPENAI_API_KEY above
# Flux via fal.ai:
FAL_KEY=                    # fal.ai API key (https://fal.ai)

# === OPTIONAL ===
SLACK_WEBHOOK_URL=          # Slack incoming webhook for daily alerts (https://api.slack.com/messaging/webhooks)
N8N_INSTANCE_URL=           # Your n8n instance URL (e.g. https://n8n.yourdomain.com)
N8N_API_KEY=                # n8n API key for automation triggers
